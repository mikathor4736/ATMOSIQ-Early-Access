{
  "version": 2,
  "installCommand": "npm install && npm --prefix=client install",
  "buildCommand": "npm --prefix=client run build",
  "outputDirectory": "./client/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
